{
  "name": "@krosoft/core",
  "version": "0.0.1",
  "description": "Helpers and types — framework agnostic",
  "type": "module",
  "exports": {
    "./helpers": {
      "import": "./dist/helpers/index.js",
      "types": "./dist/helpers/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
