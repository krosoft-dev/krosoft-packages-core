{
  "name": "@krosoft/core",
  "version": "0.0.1",
  "description": "Krosoft shared core package",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}'",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krosoft-dev/krosoft-packages-core.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./*": {
      "import": "./dist/*/index.js",
      "types": "./dist/*/index.d.ts"
    }
  },
  "devDependencies": {
    "@krosoft/tooling-eslint": "^0.0.9",
    "@krosoft/tooling-prettier": "^0.0.11",
    "@krosoft/tooling-tsconfig": "^0.0.6",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "jsdom": "^26.1.0",
    "vitest": "^4.1.3"
  }
}
